# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Security Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-characters-long
JWT_ISSUER=business-automation
JWT_AUDIENCE=business-automation-users
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SESSION_SECRET=your-session-secret-at-least-32-characters

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/business-automation
DATABASE_URL=mongodb://localhost:27017/business-automation
REDIS_URL=redis://localhost:6379

# AI Provider Configuration
# Options: 'openai', 'grok', or 'gemini'
AI_PROVIDER=gemini

# Grok API (xAI) Configuration
GROK_API_KEY=your-grok-api-key-here
XAI_API_KEY=your-xai-api-key-here
GROK_API_BASE_URL=https://api.x.ai/v1

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash

# Integration Tokens
GMAIL_ACCESS_TOKEN=your-gmail-access-token
GOOGLE_CALENDAR_TOKEN=your-google-calendar-token
SLACK_BOT_TOKEN=your-slack-bot-token

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Slack Configuration
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Twilio (for SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
